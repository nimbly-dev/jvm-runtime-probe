{
  "targets": [
    {
      "type": "class_method",
      "selectors": {
        "fqcn": "com.example.social.user.app.service.ProfileScoreService",
        "method": "recomputeProfileScore",
        "signature": "(java.lang.String,java.util.Map)",
        "sourceRoot": "test/fixtures/spring-apps/social-platform/user-service/user-app"
      }
    }
  ],
  "prerequisites": [
    {
      "key": "userId",
      "required": true,
      "secret": false,
      "default": "user-509"
    },
    {
      "key": "scoreSignalRef",
      "required": true,
      "secret": false
    }
  ],
  "steps": [
    {
      "order": 1,
      "id": "set_score_signal",
      "targetRef": 0,
      "protocol": "custom",
      "transport": {
        "custom": {
          "actionType": "invoke_method",
          "args": {
            "userId": "${userId}",
            "signalMapRef": "${scoreSignalRef}"
          }
        }
      },
      "extract": [
        {
          "from": "result.score",
          "as": "newProfileScore"
        }
      ],
      "expect": [
        {
          "id": "score_numeric",
          "actualPath": "result.score",
          "operator": "field_matches_regex",
          "expected": "^[0-9]+$"
        }
      ]
    }
  ]
}

